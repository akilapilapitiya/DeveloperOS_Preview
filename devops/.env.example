# GitLab DevOps secrets template
# Copy this file to .env and fill in the real values
# .env is gitignored and should NEVER be committed
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your_gitlab_personal_access_token_here
GITLAB_GROUP_ID=your_gitlab_group_or_namespace_id
PROJECT_NAME=developeros
GITHUB_REPO_URL=https://your_github_username:your_github_token@github.com/youruser/DeveloperOS.git
